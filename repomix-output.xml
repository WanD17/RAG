  background-clip: content-box;
}
::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.16);
  background-clip: content-box;
}

@keyframes float-slow {
  0%, 100% { transform: translate(0, 0) scale(1); }
